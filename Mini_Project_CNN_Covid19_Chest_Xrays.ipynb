## 8. Model Tuning: Hyperparameter Tuning with Keras Tuner
!pip install keras-tuner -q
import keras_tuner as kt
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Conv2D, MaxPooling2D, Flatten, Dense, Dropout
from tensorflow.keras.applications import VGG16
from tensorflow.keras.models import Model

def build_hyper_model(hp):
    model = Sequential()
    model.add(Conv2D(filters=hp.Int('conv_1_filter', min_value=32, max_value=128, step=32),
                     kernel_size=hp.Choice('conv_1_kernel', values=[3, 5]),
                     activation='relu',
                     input_shape=(IMG_SIZE, IMG_SIZE, 3)))
    model.add(MaxPooling2D(pool_size=(2, 2)))

    model.add(Conv2D(filters=hp.Int('conv_2_filter', min_value=64, max_value=256, step=32),
                     kernel_size=hp.Choice('conv_2_kernel', values=[3, 5]),
                     activation='relu'))
    model.add(MaxPooling2D(pool_size=(2, 2)))

    # Add a third Conv2D layer based on a condition
    if hp.Boolean('include_conv_3'):
        model.add(Conv2D(filters=hp.Int('conv_3_filter', min_value=128, max_value=512, step=32),
                         kernel_size=hp.Choice('conv_3_kernel', values=[3, 5]),
                         activation='relu'))
        model.add(MaxPooling2D(pool_size=(2, 2)))

    model.add(Flatten())
    model.add(Dense(units=hp.Int('dense_1_units', min_value=64, max_value=512, step=32),
                    activation='relu'))
    model.add(Dropout(rate=hp.Float('dropout_1', min_value=0.2, max_value=0.5, step=0.1)))
    model.add(Dense(y_train.shape[1], activation='softmax'))

    # Choose an optimizer
    hp_optimizer = hp.Choice('optimizer', values=['adam', 'rmsprop'])
    if hp_optimizer == 'adam':
        optimizer = 'adam'
    else:
        optimizer = 'rmsprop'

    model.compile(optimizer=optimizer,
                  loss='categorical_crossentropy',
                  metrics=['accuracy'])
    return model

# Initialize the Keras Tuner
tuner = kt.Hyperband(
    build_hyper_model,
    objective='val_accuracy',
    max_epochs=10,
    factor=3,
    hyperband_iterations=2,
    directory='keras_tuner_dir',
    project_name='covid19_cnn_tuning'
)

print("Starting hyperparameter search...")
# Run the hyperparameter search
tuner.search(
    X_train, y_train,
    epochs=20,
    validation_data=(X_val, y_val),
    callbacks=[EarlyStopping(monitor='val_loss', patience=5)] # Use early stopping during tuning
)

# Get the optimal hyperparameters
best_hps = tuner.get_best_hyperparameters(num_trials=1)[0]

print(f"\nOptimal hyperparameters found:")
for param, value in best_hps.values.items():
    print(f"  {param}: {value}")

# Build the best model and train it
best_model = tuner.hypermodel.build(best_hps)
history_tuned = best_model.fit(
    X_train, y_train,
    epochs=30,
    validation_data=(X_val, y_val),
    callbacks=[EarlyStopping(monitor='val_loss', patience=5, restore_best_weights=True)]
)

print("\nBest model training complete.")

# Evaluate the best model
loss_tuned, accuracy_tuned = best_model.evaluate(X_test, y_test, verbose=0)
print(f"\nTest Accuracy (Tuned Basic CNN Model): {accuracy_tuned:.4f}")

# Plot training history for the tuned model
plot_training_history(history_tuned, 'Tuned Basic CNN Model')

# Plot ROC curve for the tuned model
y_pred_probs_tuned = best_model.predict(X_test)
plot_roc_curve(y_test, y_pred_probs_tuned, n_classes, class_labels, 'Tuned Basic CNN Model')
